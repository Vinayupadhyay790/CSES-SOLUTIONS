#include<bits/stdc++.h>
using namespace std;
long long mod = 1000000007;
long long func(long long n, vector<long long>& dp){
    if(n==0) return 1;
    else if(n<0) return 0;
 
    if(dp[n] != -1) return dp[n];
    long long ans = 0;
    for(int i=1;i<=6;i++){
        ans += func(n-i,dp);
        ans %= mod;
    }
    return dp[n] = ans%mod;
}
int main(){
    long long n;cin >> n;
    vector<long long> dp(n+1, -1);
    
    long long x = func(n,dp);
    cout << (x%mod);
}
