#include<bits/stdc++.h>
using namespace std;
vector<int> ans;
vector<int> ans1;
static bool compare(vector<int>& a, vector<int>& b){
    if(a[0]==b[0]) return a[1]>b[1];
    return a[0]<b[0];
}
 
void merge(int start, int mid, int end, vector<vector<int>>& queries, vector<vector<int>>& temp){
    int left = start, right = mid+1;
    int k = start;
    while(left<=mid && right<=end){
        if(queries[left][1]>=queries[right][1]){
            temp[k++] = queries[right];
            right++;
        } 
        else{
            ans[queries[left][2]] += right-mid-1;
            temp[k++] = queries[left];
            left++;    
        }
    }
    while(left<=mid){
        int ind = queries[left][2];
        ans[ind] += (end-mid);
        temp[k++] = queries[left++];
    }
    while(right<=end) temp[k++] = queries[right++];
 
    for(int i=start;i<=end;i++){
        queries[i] = temp[i];
    }
}
void func(int start, int end, vector<vector<int>>& queries, vector<vector<int>>& temp){
    if(start==end) return;
    
    int mid = (start+end)/2;
    func(start,mid,queries, temp);
    func(mid+1,end,queries, temp);
    merge(start,mid,end,queries, temp);
    return;
}
 
//count larger numbers on left of it
void merge1(int start, int mid, int end, vector<vector<int>>& queries,vector<vector<int>>& temp){
    int left = start, right = mid+1;
    int k = start;
    while(left<=mid && right<=end){
        if(queries[left][1]<queries[right][1]){
            temp[k++] = queries[left];
            left++;
        }
        else{
            int ind = queries[right][2];
            ans1[ind] += mid-left+1;
            temp[k++] = queries[right];
            right++;
        }
    }
    while(left<=mid) temp[k++] = queries[left++];
    while(right<=end) temp[k++] = queries[right++];
 
    for(int i=start;i<=end;i++){
        queries[i] = temp[i];
    }
}
 
void func1(int start, int end, vector<vector<int>>& queries,vector<vector<int>>& temp){
    if(start==end) return;
    
    int mid = (start+end)/2;
    func1(start,mid,queries, temp);
    func1(mid+1,end,queries, temp);
    merge1(start,mid,end,queries, temp);
    return;
}
 
int main(){
    int n;cin >> n;
    vector<vector<int>> queries(n,vector<int>(3));
    vector<vector<int>> temp(n);
 
    for(int i=0;i<n;i++){
        cin >> queries[i][0];
        cin >> queries[i][1];
        queries[i][2] = i;
    }
 
    sort(queries.begin(),queries.end(),compare);
    vector<vector<int>> temp_queries = queries;
 
    ans.resize(n,0);
    func(0,n-1,queries,temp);
    for(int i=0;i<n;i++) cout << ans[i] << " ";
 
    cout << endl;
 
    ans1.resize(n,0);
    func1(0,n-1,temp_queries,temp);
    for(int i=0;i<n;i++) cout << ans1[i] << " ";
}
