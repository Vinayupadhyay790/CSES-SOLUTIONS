#include<bits/stdc++.h>
using namespace std;
int main(){  
    int n; cin >> n;
    vector<int> nums(n);
    for(int i=0;i<n;i++) cin >> nums[i];
 
    set<int> st;
    st.insert(nums[0]);
    int max_len = 1;
    int left = 0, right = 0;
    while(left<n){
        if(right==n-1) break;
        if(st.find(nums[right+1])!=st.end()){
            auto it = st.lower_bound(nums[left]);
            st.erase(it);
            left++;   
        }
        else{
            
            right++;
            st.insert(nums[right]);
            max_len = max(max_len,right-left+1);
        }
    }
    cout << max_len;
}
