#include<bits/stdc++.h>
using namespace std;
 
int main(){
    int n, x;
    cin >> n >> x;
 
    vector<vector<int>> arr(n,vector<int>(2));
    for(int i=0;i<n;i++){
        cin >> arr[i][0];
        arr[i][1] = i;
    }
 
    sort(arr.begin(),arr.end());
    int left = 0, right = n-1;
    bool check = true;
    while(left<right){
        int sum = arr[left][0]+arr[right][0];
        if(sum==x){
            int ind1 = arr[left][1]+1, ind2 = arr[right][1]+1;
            cout << min(ind1,ind2) << " " << max(ind1,ind2);
            check = false;
            break;
        }
        else if(sum>x) right--;
        else left++;
    }
    if(check) cout << "IMPOSSIBLE";
}
