#include<bits/stdc++.h>
using namespace std;
int main()
{
    int n, x;cin >> n >> x;
    vector<vector<int>> nums(n,vector<int> (2));
    for(int i=0;i<n;i++){
        cin >> nums[i][0];
        nums[i][1] = i;
    }
    sort(nums.begin(),nums.end());
    bool check = true;
    vector<int> ans(3);
    
    for(int i=0;i<n-2;i++){
        long long target = x-nums[i][0];
        int left = i+1,right = n-1;
        while(left<right){
            long long sum = nums[left][0] + nums[right][0];
            if(sum==target){
                check = false;
                ans[0] = nums[i][1]; ans[1] = nums[left][1]; ans[2] = nums[right][1];
                break;
            }
            else if(sum>target) right--;
            else left++;
        }
        if(!check) break;
    }
    
    sort(ans.begin(),ans.end());
 
    if(check) cout << "IMPOSSIBLE";
    else cout << ans[0]+1 << " " << ans[1]+1 << " " << ans[2]+1;
}
