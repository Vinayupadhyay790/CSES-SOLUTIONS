#include<bits/stdc++.h>
using namespace std;
int main()
{
    int n, x;cin >> n >> x;
    vector<vector<int>> nums(n, vector<int> (2));
 
    for(int i=0;i<n;i++){
        cin >> nums[i][0];
        nums[i][1] = i;
    }
 
    sort(nums.begin(),nums.end());
    vector<int> ans(4);
    bool check = true; 
 
    for(int i=0;i<n-3;i++){
        for(int j=i+1;j<n-2;j++){
            long long target = x-nums[i][0]-nums[j][0];
            int left = j+1, right = n-1;
            while(left<right){
                long long sum = nums[left][0]+nums[right][0];
                if(sum == target){
                    ans[0]=nums[i][1],ans[1]=nums[j][1],ans[2]=nums[left][1],ans[3]=nums[right][1];
                    check = false;
                    break;
                }
                if(sum>target) right--;
                else left++;
            }
        }
        if(!check) break;
    }
 
    sort(ans.begin(),ans.end());
    if(check) cout << "IMPOSSIBLE";
    else cout << ans[0]+1<<" "<<ans[1]+1<<" "<<ans[2]+1<<" "<<ans[3]+1;
}
