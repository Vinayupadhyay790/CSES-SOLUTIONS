#include<bits/stdc++.h>
using namespace std;
int main()
{
    int n, x;
    cin >> n >> x;
    vector<long long> nums(n);
    for(int i=0;i<n;i++) cin >> nums[i];
 
    sort(nums.begin(),nums.end());
    long long count = 0;
    long long left = 0, right = n-1;
    
    while(left<right){
        if((nums[left]+nums[right]) <= x){
            left++;
            right--;
        }
        else right--;
        
        count++;
    }
    if(left==right) count++;
 
    cout << count;
}
