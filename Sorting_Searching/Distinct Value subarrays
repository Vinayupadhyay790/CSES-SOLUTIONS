#include<bits/stdc++.h>
using namespace std;
int main()
{
    int n;cin >> n;
    vector<int> nums(n);
    for(int i=0;i<n;i++) cin >> nums[i];
 
    set<int> st;
    st.insert(nums[0]);
 
    int left = 0, right = 0;
    long long count = 0;
    while(left<n){
        if(right==n-1){
            while(left<n){
                count += (right-left+1);
                left++;
            }
        }
        if(st.find(nums[right+1])!=st.end()){
            count += right-left+1;
            auto it = st.lower_bound(nums[left++]);
            st.erase(it);
        }
        else{
            right++;
            st.insert(nums[right]);
        }
    }
    cout << count;
}
