#include<bits/stdc++.h>
using namespace std;
int main()
{
    int n;cin >> n;
    vector<bool> is_there(n,true);
 
    int i=0;
    int idx=0,count=0;
    while(idx<n){
        if(count==n) break;
        if(is_there[idx] && (i%2)==1){
            cout << idx+1 << " ";
            count++;
            i++;
            is_there[idx] = false;
        }else if(is_there[idx]) i++;
        idx++;
        i%=2;
        idx%=n;
    } 
}
