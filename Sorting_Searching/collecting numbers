#include<bits/stdc++.h>
using namespace std;
 
int main(){
    long long n;cin>>n;
    map<int,int> mp;
    for(int i=0;i<n;i++){
        int x;cin >> x;
        mp[x] = i;
    }
    int count = 0,prev_idx = -1;
    for(auto it : mp){
        if(prev_idx==-1){
            count++;
            prev_idx = it.second;
        }
        else{
            if(it.second>prev_idx){
                prev_idx = it.second;
            }
            else{
                count++;
                prev_idx = it.second;
            }
        }
    }
    cout << count;
    
}
