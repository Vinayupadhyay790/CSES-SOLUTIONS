#include<bits/stdc++.h>
using namespace std;
int main()
{
    int n;cin >> n;
    vector<vector<int>> nums(n,vector<int>(2));
    for(int i=0;i<n;i++){
        cin >> nums[i][0];
        cin >> nums[i][1];
    }
 
    sort(nums.begin(), nums.end());
 
    long long time = 0, profit = 0;
    for(int i=0;i<n;i++){
        time += nums[i][0];
        profit += (nums[i][1]-time);
    }
    cout << profit;
}
