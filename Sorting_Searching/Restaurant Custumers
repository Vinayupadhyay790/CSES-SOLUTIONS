#include<bits/stdc++.h>
using namespace std;
int main()
{
    long long n;cin >> n;
    vector<pair<long long,long long>> arr(n);
    for(int i=0;i<n;i++){
        long long a, b;
        cin >> a >> b;
        pair<long long,long long> p = {a,b};
        arr[i] = p;
    }
    
    map<long long, long long> mp;
    for(auto& it : arr){
        long long first_num = it.first;
        long long second_num = it.second;
        mp[first_num]++;
        mp[second_num+1]--;
    }
    long long curr_count = 0;
    long long maxi = LLONG_MIN;
    for(auto & it : mp){
        curr_count += it.second;
        maxi = max(maxi, curr_count);
    }
    
    cout << maxi << endl;
}
