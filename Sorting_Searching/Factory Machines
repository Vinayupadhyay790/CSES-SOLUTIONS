#include<bits/stdc++.h>
using namespace std;
 
long long func(vector<long long>& nums, long long mid){
    long long products = 0;
    long long n = nums.size();
 
    for(long long i=0;i<n;i++){
        products += mid/nums[i];
        if(nums[i]>mid) break;
    }
    return products;
}
int main(){
    long long n, t;
    cin >> n >> t;
 
    vector<long long> nums(n);
    for(int i=0;i<n;i++) cin >> nums[i];
    sort(nums.begin(),nums.end());
 
    long long left = 1LL, right = nums[0]*t + 1;
    long long ans = -1;
    while(left<=right){
        long long mid = right - (right-left)/2;
        long long x = func(nums,mid);   // returns max number of prducts made using this time optimally
        if(x>=t){
            ans = mid;
            right = mid-1;
        }
        else left = mid+1;
    }
    cout << ans;
}
