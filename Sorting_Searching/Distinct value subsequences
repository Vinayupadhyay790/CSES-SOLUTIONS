#include<bits/stdc++.h>
using namespace std;
int main()
{
    int n;cin >>n;
    vector<int> nums(n);
    for(int i=0;i<n;i++) cin >> nums[i];
 
    unordered_map<int,int> mp;
    for(int i=0;i<n;i++) mp[nums[i]]++;
    int mod = 1000000007;
    long long count = 1;
    for(auto it : mp){
        count *= 1LL * (it.second+1);
        count %= mod;
    }
    
    cout << (count-1);
}
